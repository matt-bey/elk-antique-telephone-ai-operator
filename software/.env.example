# Antique Telephone AI Operator — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Required: Anthropic API key for conversation AI (Haiku model)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override conversation provider (default: anthropic)
# CONVERSATION_PROVIDER=ollama

# Optional: SIP/VoIP credentials (Callcentric by default)
# SIP_USERNAME=1777xxxxxxxEXT     # Callcentric DID + extension (e.g. 17770001234101)
# SIP_PASSWORD=your-password      # Callcentric extension SIP password
# SIP_DOMAIN=sip.callcentric.net  # override registrar (default: sip.callcentric.net)
# SIP_LOCAL_AREA_CODE=614         # prepended to 7-digit numbers (US dialing)

# Optional: Google Places API for business name lookup
# GOOGLE_PLACES_API_KEY=AIza...
# GCP_PROJECT_ID=my-gcp-project   # GCP project ID that owns the API key

# Optional: home location for proximity-biased business searches
# HOME_LAT=40.7128
# HOME_LON=-74.0060

# Optional: override log level (DEBUG, INFO, WARNING) and log file path
# LOG_LEVEL=INFO
# LOG_FILE=/var/log/antique-telephone.log
